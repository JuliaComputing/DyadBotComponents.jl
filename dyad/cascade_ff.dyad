"Wraps a scalar input signal into a 1-element signal array, for connecting scalar outputs to array inputs."
component Mux1
  u = Dyad.RealInput() {^u}
  y = [Dyad.RealOutput() for i in 1:1] {^y}
relations
  y = [u]
metadata {
  "Dyad": {"icons": {"default": "dyad://MultibodyComponents/Mux1.svg"}},
  "_links": {
    "u": {
      "Dyad": {
        "placement": {
          "diagram": {"iconName": "default", "x1": -100, "y1": 450, "x2": 0, "y2": 550, "rot": 0}
        },
        "tags": []
      }
    },
    "y": {
      "Dyad": {
        "placement": {
          "diagram": {"iconName": "default", "x1": 1000, "y1": 450, "x2": 1100, "y2": 550, "rot": 0}
        },
        "tags": []
      }
    }
  }
}
end

"""
Continuous-time cascade control system with feed-forward for the balancing
robot. Extends the plain cascade control system with three feed-forward signals
supplied by an external feed-forward generator: a filtered position reference
for the outer loop, a tilt-angle feed-forward for the inner-loop reference, and
a direct torque feed-forward on the motor command. The two inner feed-forward
signals enter through the `u_ff` ports of the `LimPID` controllers.

The control system has a purely continuous interface so it can be swapped for
`DiscreteCascadeFFController` without any other change to the closed-loop model.
"""
component CascadeFFController
  "Body tilt-angle measurement"
  angle_measurement = Dyad.RealInput() {^angle_measurement}
  "Wheel-axis position measurement"
  pos_measurement = Dyad.RealInput() {^pos_measurement}
  "Filtered position reference (from the feed-forward generator)"
  pos_reference = Dyad.RealInput() {^pos_reference}
  "Tilt-angle feed-forward (from the feed-forward generator)"
  angle_ff = Dyad.RealInput() {^angle_ff}
  "Torque feed-forward (from the feed-forward generator)"
  torque_ff = Dyad.RealInput() {^torque_ff}
  "Motor torque command"
  torque = Dyad.RealOutput() {^torque}
  angle_controller = BlockComponents.Continuous.LimPID(k = 0.487401, Ti = 0.0587352, Td = 0.0420526, Nd = 119.368, y_max = 0.1) {^angle_controller}
  pos_controller = BlockComponents.Continuous.LimPID(k = 0.0666576, Ti = 5.25024, Td = 4.81393, Nd = 4.76616, wd = 1, wp = 1, y_max = deg2rad(25.0)) {^pos_controller}
  gain = BlockComponents.Math.Gain(k = -1) {^gain}
  gain1 = BlockComponents.Math.Gain(k = -1) {^gain1}
  "This negative gain is required since we are providing the angle reference signal to the `u_ff` connector of the outer controller which sits behind the negative gain `gain1`. We are thus effectively negating `gain1` with this `gain2`."
  gain2 = BlockComponents.Math.Gain(k = -1) {^gain2}
relations
  y: analysis_point(angle_measurement, angle_controller.u_m)
  y2: analysis_point(pos_measurement, pos_controller.u_m)
  u: analysis_point(angle_controller.y, gain.u)
  u2: analysis_point(pos_controller.y, gain1.u)
  connect(angle_measurement, angle_controller.u_m) {^id12}
  connect(pos_measurement, pos_controller.u_m) {^id13}
  connect(pos_controller.y, gain1.u) {^id14}
  connect(gain1.y, angle_controller.u_s) {^id15}
  connect(gain.y, torque) {^id16}
  connect(angle_controller.y, gain.u) {^id17}
  connect(pos_reference, pos_controller.u_s) {^id18}
  connect(angle_ff, gain2.u) {^id19}
  connect(torque_ff, angle_controller.u_ff) {^id20}
  connect(gain2.y, pos_controller.u_ff) {^id21}
metadata {
  "Dyad": {"icons": {"default": "dyad://DyadBotComponents/CascadeFFController.svg"}},
  "_links": {
    "angle_measurement": {
      "Dyad": {
        "placement": {"diagram": {"x1": 700, "y1": 950, "x2": 800, "y2": 1050, "rot": 270}}
      }
    },
    "pos_measurement": {
      "Dyad": {
        "placement": {"diagram": {"x1": 130, "y1": 960, "x2": 230, "y2": 1060, "rot": 270}}
      }
    },
