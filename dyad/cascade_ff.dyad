      "Dyad": {"placement": {"diagram": {"iconName": "default", "x1": 20, "y1": 460, "x2": 100, "y2": 540, "rot": 0}}, "tags": []}
    },
    "gain2": {
      "Dyad": {"placement": {"diagram": {"iconName": "default", "x1": -160, "y1": 330, "x2": -80, "y2": 410, "rot": 0}}, "tags": []}
    },
