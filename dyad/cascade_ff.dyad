"""
Discrete-time version of `CascadeFFController`. Drop-in replacement with the same
continuous interface. Both loops are sampled-data `DiscretePIDStandard`
controllers on a common `PeriodicClock` with period `Ts`. The measurements and
the three feed-forward signals are sampled by `Sampler` blocks and a
`ZeroOrderHold` reconstructs the continuous torque.

The feed-forward signals are supplied through the native `u_ff` inputs of
`DiscretePIDStandard` (`with_ff = true`), mirroring the continuous `LimPID`
`u_ff` ports. The tilt-angle feed-forward uses `k_ff = -1` on the position
controller, which replaces the explicit negating `gain2` of the continuous
controller.
"""
component DiscreteCascadeFFController
  "Body tilt-angle measurement"
  angle_measurement = Dyad.RealInput() {^angle_measurement}
  "Wheel-axis position measurement"
  pos_measurement = Dyad.RealInput() {^pos_measurement}
  "Filtered position reference (from the feed-forward generator)"
  pos_reference = Dyad.RealInput() {^pos_reference}
  "Tilt-angle feed-forward (from the feed-forward generator)"
  angle_ff = Dyad.RealInput() {^angle_ff}
  "Torque feed-forward (from the feed-forward generator)"
  torque_ff = Dyad.RealInput() {^torque_ff}
  "Motor torque command"
  torque = Dyad.RealOutput() {^torque}
  angle_controller = DiscreteComponents.DiscretePIDStandard(with_ff = true, K = 0.487401, Ti = 0.0587352, Td = 0.0420526, Nd = 119.368, y_max = 0.1) {^angle_controller}
  pos_controller = DiscreteComponents.DiscretePIDStandard(with_ff = true, k_ff = -1, K = 0.0666576, Ti = 5.25024, Td = 4.81393, Nd = 4.76616, wd = 1, wp = 1, y_max = deg2rad(25.0)) {^pos_controller}
  gain = BlockComponents.Math.Gain(k = -1) {^gain}
  gain1 = BlockComponents.Math.Gain(k = -1) {^gain1}
  sampler_theta = DiscreteComponents.Sampler() {^sampler_theta}
  sampler_x = DiscreteComponents.Sampler() {^sampler_x}
  sampler_posref = DiscreteComponents.Sampler() {^sampler_posref}
  sampler_angleff = DiscreteComponents.Sampler() {^sampler_angleff}
  sampler_torqueff = DiscreteComponents.Sampler() {^sampler_torqueff}
  zoh = DiscreteComponents.ZeroOrderHold() {^zoh}
  clock = DiscreteComponents.PeriodicClock(dt = Ts) {^clock}
  "Controller sample interval"
  structural parameter Ts::Real = 0.005
relations
  connect(pos_reference, sampler_posref.u) {^id1}
  connect(sampler_posref.y, pos_controller.u_s) {^id2}
  connect(pos_measurement, sampler_x.u) {^id3}
  connect(sampler_x.y, pos_controller.u_m) {^id4}
  connect(angle_ff, sampler_angleff.u) {^id5}
  connect(sampler_angleff.y, pos_controller.u_ff) {^id6}
  connect(pos_controller.y, gain1.u) {^id7}
  connect(gain1.y, angle_controller.u_s) {^id8}
  connect(torque_ff, sampler_torqueff.u) {^id9}
  connect(sampler_torqueff.y, angle_controller.u_ff) {^id10}
  connect(angle_measurement, sampler_theta.u) {^id11}
  connect(sampler_theta.y, angle_controller.u_m, clock.y) {^id12}
  connect(angle_controller.y, gain.u) {^id13}
  connect(gain.y, zoh.u) {^id14}
  connect(zoh.y, torque) {^id15}
metadata {
  "Dyad": {
    "icons": {"default": "dyad://DyadBotComponents/PlanarDyadBot.svg"}
  },
  "_links": {
    "angle_measurement": {
      "Dyad": {"placement": {"diagram": {"x1": 320, "y1": 640, "x2": 420, "y2": 740}}}
    },
    "pos_measurement": {
      "Dyad": {"placement": {"diagram": {"x1": -180, "y1": 640, "x2": -80, "y2": 740}}}
    },
    "pos_reference": {
      "Dyad": {"placement": {"diagram": {"x1": -460, "y1": 450, "x2": -360, "y2": 550}}}
    },
    "angle_ff": {
      "Dyad": {"placement": {"diagram": {"x1": -460, "y1": 320, "x2": -360, "y2": 420}}}
    },
    "torque_ff": {
      "Dyad": {"placement": {"diagram": {"x1": 60, "y1": 320, "x2": 160, "y2": 420}}}
    },
    "torque": {
      "Dyad": {"placement": {"diagram": {"x1": 560, "y1": 450, "x2": 660, "y2": 550}}}
    },
    "angle_controller": {
      "Dyad": {"placement": {"diagram": {"iconName": "default", "x1": 160, "y1": 450, "x2": 260, "y2": 550, "rot": 0}}, "tags": []}
    },
    "pos_controller": {
