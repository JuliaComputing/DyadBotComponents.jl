"""
Cascade-controlled balancing robot with a feedforward generator.

This is a continuation of CascadeControlledDyadBot, adding a feedforward
generator computed with the script `scripts/compute_feedforward.jl`. The
feedforward generator provides a filtered position reference to the outer
controller as well as a tilt-angle feedforward reference for the inner
controller and a direct torque feedforward signal applied to the motor
torque input.

The control system is encapsulated in the `CascadeFFController` subcomponent;
the discrete-time model `DiscreteCascadeFFDyadBot` is identical except that
`controller` is a `DiscreteCascadeFFController`.
"""
component CascadeFFDyadBot
  world = MultibodyComponents.PlanarMechanics.World(g = 9.82) {^world}
  plant = PlanarDyadBot(phi0 = phi0) {^plant}
  square = BlockComponents.Sources.Square(amplitude = 0.05, frequency = 1 / 10) {^square}
  """
  refgen has 1 input (position reference) and 3 outputs:
     y[1]: angle feedforward
     y[2]: filtered position reference
     y[3]: torque feedforward
  """
  refgen = BlockComponents.Continuous.StateSpace(nx = ff_nx(), nu = 1, ny = 3, A = ff_A(), B = ff_B(), C = ff_C(), D = ff_D()) {^refgen}
  angle_ff = MultibodyComponents.Selector(nu = 3) {^angle_ff}
  pos_ref = MultibodyComponents.Selector(nu = 3, index = 2) {^pos_ref}
  torque_ff = MultibodyComponents.Selector(nu = 3, index = 3) {^torque_ff}
  mux1 = Mux1() {^mux1}
  controller = CascadeFFController() {^controller}
  "Initial tilt angle of the body"
  parameter phi0::Angle = 0.1
relations
  connect(plant.theta, controller.angle_measurement) {^id10}
  connect(plant.x, controller.pos_measurement) {^id11}
  connect(controller.torque, plant.torque) {^id12}
  connect(torque_ff.y, controller.torque_ff) {^id13}
  connect(angle_ff.y, controller.angle_ff) {^id14}
  connect(pos_ref.y, controller.pos_reference) {^id15}
  connect(refgen.y, pos_ref.u, angle_ff.u, torque_ff.u) {^id16}
  connect(square.y, mux1.u) {^id17}
  connect(mux1.y, refgen.u) {^id18}
metadata {
