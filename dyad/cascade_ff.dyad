    "id7": {
      "Dyad": {
        "edges": [{"S": 1, "M": [{"x": 660, "y": 468}, {"x": 660, "y": 720}, {"x": 30, "y": 720}, {"x": 30, "y": 620}], "E": 2}]
      }
