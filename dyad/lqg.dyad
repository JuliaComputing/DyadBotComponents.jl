"""
Analysis model for LQG controller design for the balancing robot.

The loop is closed with a negligibly small static output feedback so that the
model is a well-posed closed-loop system, and analysis points are placed on
all four measured outputs (`y_x`, `y_xd`, `y_theta`, `y_thetad`) and on the
control input (`u`). The LQG design script `scripts/tune_lqg.jl` opens the
loop at `u` and synthesizes an LQG controller from the linearized plant.
"""
component LQGTuningDyadBot
  world = MultibodyComponents.PlanarMechanics.World(g = 9.82) {^world}
  plant = PlanarDyadBot() {^plant}
  g_x = BlockComponents.Math.Gain(k = 1e-10) {^g_x}
  g_xd = BlockComponents.Math.Gain(k = 1e-10) {^g_xd}
  g_theta = BlockComponents.Math.Gain(k = 1e-10) {^g_theta}
  g_thetad = BlockComponents.Math.Gain(k = 1e-10) {^g_thetad}
  add3 = BlockComponents.Math.Add3() {^add3}
  add = BlockComponents.Math.Add() {^add}
relations
  y_x: analysis_point(plant.x, g_x.u)
  y_xd: analysis_point(plant.x_dot, g_xd.u)
  y_theta: analysis_point(plant.theta, g_theta.u)
  y_thetad: analysis_point(plant.theta_dot, g_thetad.u)
  u: analysis_point(add.y, plant.torque)
  connect(plant.x, g_x.u) {^id1}
  connect(plant.x_dot, g_xd.u) {^id2}
  connect(plant.theta, g_theta.u) {^id3}
  connect(plant.theta_dot, g_thetad.u) {^id4}
  connect(g_x.y, add3.u1) {^id5}
  connect(g_xd.y, add3.u2) {^id6}
  connect(g_theta.y, add3.u3) {^id7}
  connect(add3.y, add.u1) {^id8}
  connect(g_thetad.y, add.u2) {^id9}
  connect(add.y, plant.torque) {^id10}
metadata {
  "Dyad": {
    "icons": {"default": "dyad://DyadBotComponents/PlanarDyadBot.svg"}
  },
  "_links": {
    "world": {
      "Dyad": {
        "placement": {
