"Wraps six scalar input signals into a 6-element signal array, for connecting scalar outputs to array inputs."
component Mux6
  u1 = Dyad.RealInput() {^u1}
  u2 = Dyad.RealInput() {^u2}
  u3 = Dyad.RealInput() {^u3}
  u4 = Dyad.RealInput() {^u4}
  u5 = Dyad.RealInput() {^u5}
  u6 = Dyad.RealInput() {^u6}
  y = [Dyad.RealOutput() for i in 1:6] {^y}
relations
  y = [u1, u2, u3, u4, u5, u6]
metadata {
  "Dyad": {"icons": {"default": "dyad://MultibodyComponents/Mux1.svg"}},
  "_links": {
    "u1": {
      "Dyad": {
        "placement": {
