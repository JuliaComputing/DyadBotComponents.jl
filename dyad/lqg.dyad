"""
Balancing robot stabilized by an LQG controller with reference feedforward.

The controller is a state-space system computed by the LQG design script
`scripts/tune_lqg.jl` and loaded from CSV files. Its six inputs are the
references for position, velocity, tilt angle and tilt rate, followed by the
measured position and tilt angle. Its single output is the motor torque.
The position reference steps from zero to `step_height` at `step_time`.
"""
component LQGControlledDyadBot
  world = MultibodyComponents.PlanarMechanics.World(g = 9.82) {^world}
  plant = PlanarDyadBot(phi0 = phi0) {^plant}
  controller = BlockComponents.Continuous.StateSpace(nx = lqg_nx(), nu = 6, ny = 1, A = lqg_A(), B = lqg_B(), C = lqg_C(), D = lqg_D()) {^controller}
  step = BlockComponents.Sources.Step(final height = step_height, final start_time = step_time) {^step}
  zero_xd = BlockComponents.Sources.Constant(k = 0) {^zero_xd}
  zero_theta = BlockComponents.Sources.Constant(k = 0) {^zero_theta}
  zero_thetad = BlockComponents.Sources.Constant(k = 0) {^zero_thetad}
  mux = Mux6() {^mux}
  torque_out = MultibodyComponents.Selector(nu = 1) {^torque_out}
  "Height of the position reference step"
  parameter step_height::Length = 0.15
  "Time at which the position reference steps"
  parameter step_time::Time = 5
  "Initial tilt angle of the body"
  parameter phi0::Angle = 0.1
relations
  u: analysis_point(torque_out.y, plant.torque)
  connect(step.y, mux.u1) {^id1}
  connect(zero_xd.y, mux.u2) {^id2}
  connect(zero_theta.y, mux.u3) {^id3}
  connect(zero_thetad.y, mux.u4) {^id4}
  connect(plant.x, mux.u5) {^id5}
  connect(plant.theta, mux.u6) {^id6}
  connect(mux.y, controller.u) {^id7}
  connect(controller.y, torque_out.u) {^id8}
  connect(torque_out.y, plant.torque) {^id9}
metadata {
  "Dyad": {
    "tests": {"case1": {"stop": 20}},
    "icons": {"default": "dyad://DyadBotComponents/PlanarDyadBot.svg"}
  },
  "_links": {
    "world": {
