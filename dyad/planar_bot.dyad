"""
A simple motor model consisting of an ideal torque source acting on a revolute joint, with viscous friction acting between the rotor and the stator.
"""
component SimpleMotor
  extends MultibodyComponents.PlanarMechanics.PartialTwoFrames
  torquesource = RotationalComponents.Sources.TorqueSource() {^torquesource}
  motor_rotation = MultibodyComponents.PlanarMechanics.Revolute(render = false) {^motor_rotation}
  damper = RotationalComponents.Components.Damper(d = d) {^damper}
  "Torque command"
  torqueinput = Dyad.RealInput() {^torqueinput}
  fixed = RotationalComponents.Components.Fixed() {^fixed}
  "Viscous friction coefficient"
  parameter d::RotationalDampingConstant = 0.0
relations
  connect(torquesource.spline, motor_rotation.flange_a, damper.spline_a) {^id6}
  connect(frame_a, motor_rotation.frame_a) {^id7}
  connect(motor_rotation.frame_b, frame_b) {^id8}
  connect(torquesource.support, damper.spline_b, fixed.spline) {^id9}
  connect(torqueinput, torquesource.tau) {^id10}
metadata {
  "Dyad": {
    "icons": {"default": "dyad://MultibodyComponents/Revolute.svg"},
    "labels": [
      {
        "label": "$(instance)",
        "x": 500,
        "y": 200,
        "rot": 0,
        "attrs": {"font-size": "160"}
      }
    ]
  },
  "_links": {
    "torquesource": {
      "Dyad": {
