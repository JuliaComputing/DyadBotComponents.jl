"""
Planar model of a two-wheeled balancing robot.

The robot consists of a wheel rolling without slip along the ground, an
inverted-pendulum body mounted on the wheel axis through a motor, and an
IMU-like sensor measuring the position of the wheel axis and the tilt angle
of the body. The motor applies the commanded torque between the body and the
wheel.

Inputs and outputs:
- `torque`: torque applied by the motor between body and wheel
- `x`, `x_dot`: position and velocity of the wheel axis along the ground
- `theta`, `theta_dot`: tilt angle and tilt rate of the body (zero when upright)

The model must be accompanied by a `MultibodyComponents.PlanarMechanics.World`
component in the top level of the enclosing model.
"""
component PlanarDyadBot
  wheelJoint = MultibodyComponents.PlanarMechanics.OneDOFRollingWheelJoint(radius = R) {^wheelJoint}
  wheelinertia = MultibodyComponents.PlanarMechanics.Body(I = Iw, radius = 0.01, m = m, phi = initial 0.0, w = initial 0.0) {^wheelinertia}
  simplemotor = SimpleMotor(d = d) {^simplemotor}
  body_mass = MultibodyComponents.PlanarMechanics.BodyShape(color = [0.2, 0.2, 0.2, 0.9], r = [0, 2 * L], r_cm = [0, L], m = M, I = Ib, radius = 0.03, body(w = initial 0.0)) {^body_mass}
  IMU = MultibodyComponents.PlanarMechanics.AbsolutePosition(resolve_in_frame = MultibodyComponents.ResolveInFrame.World()) {^IMU}
  "Motor torque command"
  torque = Dyad.RealInput() {^torque}
  "Position of the wheel axis"
  x = Dyad.RealOutput() {^x}
  "Body tilt angle"
  theta = Dyad.RealOutput() {^theta}
  "Velocity of the wheel axis"
  x_dot = Dyad.RealOutput() {^x_dot}
  "Body tilt rate"
  theta_dot = Dyad.RealOutput() {^theta_dot}
  "Body mass"
  parameter M::Mass = 0.1
  "Wheel mass"
  parameter m::Mass = 0.05
  "Wheel radius"
  parameter R::Length = 0.04
  "Distance from wheel axis to body center of mass"
  parameter L::Length = 0.08
  "Body moment of inertia"
  parameter Ib::Inertia = 2.5e-4
  "Wheel + motor moment of inertia"
  parameter Iw::Inertia = 1e-4
  "Motor viscous friction"
  parameter d::RotationalDampingConstant = 0.0001
  "Initial tilt angle of the body"
  parameter phi0::Angle = 0.0
relations
  initial body_mass.body.phi = phi0
  connect(wheelinertia.frame_a, wheelJoint.frame_a) {^id1}
  connect(simplemotor.frame_b, wheelJoint.frame_a) {^id2}
  connect(simplemotor.frame_a, IMU.frame_a, body_mass.frame_a) {^id3}
  connect(torque, simplemotor.torqueinput) {^id4}
  x = IMU.x
  theta = IMU.phi
  x_dot = wheelJoint.v
  theta_dot = body_mass.body.w
metadata {
  "Dyad": {
    "icons": {"default": "dyad://DyadBotComponents/PlanarDyadBot.svg"},
    "labels": [
      {
        "label": "$(instance)",
        "x": 500,
