"""
Discrete-time version of `AngleControlledDyadBot`. Identical to the continuous
model except that the control system is a sampled-data `DiscreteAngleController`
(`DiscretePIDStandard` with a `Sampler`, `ZeroOrderHold` and `PeriodicClock`).
The sample interval is set by the top-level structural parameter `Ts`.
"""
component DiscreteAngleControlledDyadBot
  extends AngleControllerParams
  world = MultibodyComponents.PlanarMechanics.World(g = 9.82, nominal_length = 0.1) {^world}
  plant = PlanarDyadBot(phi0 = phi0) {^plant}
  controller = DiscreteAngleController(k_angle = k_angle, Ti_angle = Ti_angle, Td_angle = Td_angle, Ts = Ts) {^controller}
  "Initial tilt angle of the body"
  parameter phi0::Angle = 0.1
  "Controller sample interval"
  structural parameter Ts::Real = 0.005
relations
  connect(controller.torque, plant.torque) {^id4}
  connect(plant.theta, controller.measurement) {^id5}
