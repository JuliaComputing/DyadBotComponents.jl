"""
Balancing robot with a cascade control system: an inner loop stabilizes the
body tilt angle and an outer loop controls the position of the robot along
the ground. The position reference is a square wave filtered through two
first-order filters to obtain a smooth reference trajectory.

The control system is encapsulated in the `CascadeController` subcomponent; the
discrete-time model `DiscreteCascadeControlledDyadBot` is identical except that
`controller` is a `DiscreteCascadeController`.

The six controller gains are exposed as top-level parameters so that they can
be tuned, either one loop at a time with the scripts `scripts/tune_angle_pid.jl`
and `scripts/tune_cascade_pid.jl`, or all simultaneously with
`scripts/tune_cascade_structured.jl`.
"""
component CascadeControlledDyadBot
  extends CascadeControllerParams
  world = MultibodyComponents.PlanarMechanics.World(g = 9.82, nominal_length = 0.1) {^world}
  plant = PlanarDyadBot(phi0 = phi0) {^plant}
  square = BlockComponents.Sources.Square(amplitude = 0.05, frequency = 1 / 10) {^square}
  firstorder = BlockComponents.Continuous.FirstOrder(T = 0.1) {^firstorder}
  firstorder1 = BlockComponents.Continuous.FirstOrder(T = 0.1) {^firstorder1}
  controller = CascadeController(k_angle = k_angle, Ti_angle = Ti_angle, Td_angle = Td_angle, k_pos = k_pos, Ti_pos = Ti_pos, Td_pos = Td_pos) {^controller}
  "Initial tilt angle of the body"
  parameter phi0::Angle = 0.1
relations
  initial firstorder.x = 0.0
  initial firstorder1.x = 0.0
  connect(square.y, firstorder.u) {^id7}
  connect(firstorder.y, firstorder1.u) {^id8}
  connect(controller.torque, plant.torque) {^id9}
  connect(plant.theta, controller.angle_measurement) {^id10}
  connect(plant.x, controller.pos_measurement) {^id11}
  connect(firstorder1.y, controller.pos_reference) {^id12}
metadata {
  "Dyad": {
    "tests": {"case1": {"stop": 20}},
    "icons": {"default": "dyad://DyadBotComponents/PlanarDyadBot.svg"}
  },
  "_links": {
    "world": {
      "Dyad": {
        "placement": {
          "diagram": {"iconName": "default", "x1": 110, "y1": 250, "x2": 10, "y2": 150, "rot": 180}
        },
        "tags": []
      }
    },
    "plant": {
      "Dyad": {
        "placement": {
          "diagram": {"iconName": "default", "x1": 600, "y1": 400, "x2": 800, "y2": 600, "rot": 0}
        },
        "tags": []
      }
    },
    "square": {
      "Dyad": {"placement": {"diagram": {"x1": -230, "y1": 450, "x2": -130, "y2": 550}}}
    },
    "firstorder": {
      "Dyad": {"placement": {"diagram": {"x1": -90, "y1": 450, "x2": 10, "y2": 550}}}
    },
    "firstorder1": {
      "Dyad": {"placement": {"diagram": {"x1": 60, "y1": 450, "x2": 160, "y2": 550}}}
    },
    "controller": {
      "Dyad": {"placement": {"diagram": {"x1": 265, "y1": 410, "x2": 455, "y2": 600}}}
    },
    "id7": {"Dyad": {"edges": [{"S": 1, "M": [], "E": 2}]}},
    "id8": {"Dyad": {"edges": [{"S": 1, "M": [], "E": 2}]}},
    "id9": {
      "Dyad": {"edges": [{"S": 1, "M": [{"x": 501, "y": 505}, {"x": 501, "y": 500}], "E": 2}]}
    },
