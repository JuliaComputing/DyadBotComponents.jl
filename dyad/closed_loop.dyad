"""
Balancing robot stabilized by a single PID controller regulating the body
tilt angle to zero. The robot starts from a tilted initial configuration and
the controller recovers the upright pose. Since only the angle is controlled,
the position of the robot drifts freely.

The controller gains can be tuned with the script `scripts/tune_angle_pid.jl`.
"""
component AngleControlledDyadBot
  world = MultibodyComponents.PlanarMechanics.World(g = 9.82) {^world}
  plant = PlanarDyadBot(phi0 = phi0) {^plant}
  angle_controller = BlockComponents.Continuous.LimPID(final k = k_angle, final Ti = Ti_angle, final Td = Td_angle, Nd = 119.368, y_max = 0.1) {^angle_controller}
  ref = BlockComponents.Sources.Constant(k = 0) {^ref}
  gain = BlockComponents.Math.Gain(k = -1) {^gain}
  constant_ff = BlockComponents.Sources.Constant(k = 0) {^constant_ff}
  "Proportional gain of the angle controller"
  parameter k_angle::Real = 0.487401
  "Integrator time constant of the angle controller"
  parameter Ti_angle::Time = 0.0587352
  "Derivative time constant of the angle controller"
  parameter Td_angle::Time = 0.0420526
  "Initial tilt angle of the body"
  parameter phi0::Angle = 0.1
relations
  y: analysis_point(plant.theta, angle_controller.u_m)
  u: analysis_point(angle_controller.y, gain.u)
  connect(plant.theta, angle_controller.u_m) {^id7}
  connect(angle_controller.y, gain.u) {^id8}
  connect(gain.y, plant.torque) {^id9}
  connect(constant_ff.y, angle_controller.u_ff) {^id10}
  connect(ref.y, angle_controller.u_s) {^id11}
metadata {
  "Dyad": {
    "tests": {"case1": {"stop": 5}},
    "icons": {"default": "dyad://DyadBotComponents/PlanarDyadBot.svg"}
  },
  "_links": {
    "world": {
      "Dyad": {
        "placement": {
          "diagram": {"iconName": "default", "x1": 200, "y1": 250, "x2": 100, "y2": 150, "rot": 180}
        },
