"""
Discrete-time version of `CascadeController`. Drop-in replacement with the same
continuous interface: both the inner angle loop and the outer position loop are
sampled-data `DiscretePIDStandard` controllers on a common `PeriodicClock` with
period `Ts`. The continuous measurements and the filtered position reference are
sampled by `Sampler` blocks and a `ZeroOrderHold` reconstructs the continuous
torque.
"""
component DiscreteCascadeController
  extends CascadeControllerParams
  "Body tilt-angle measurement"
  angle_measurement = Dyad.RealInput() {^angle_measurement}
  "Wheel-axis position measurement"
  pos_measurement = Dyad.RealInput() {^pos_measurement}
  "Filtered position reference"
  pos_reference = Dyad.RealInput() {^pos_reference}
  "Motor torque command"
  torque = Dyad.RealOutput() {^torque}
  angle_controller = DiscreteComponents.DiscretePIDStandard(final K = k_angle, final Ti = Ti_angle, final Td = Td_angle, Nd = 119.368, y_max = 0.1) {^angle_controller}
  pos_controller = DiscreteComponents.DiscretePIDStandard(final K = k_pos, final Ti = Ti_pos, final Td = Td_pos, Nd = 4.76616, wd = 1, wp = 1, y_max = deg2rad(25.0)) {^pos_controller}
  gain = BlockComponents.Math.Gain(k = -1) {^gain}
  gain1 = BlockComponents.Math.Gain(k = -1) {^gain1}
  sampler_theta = DiscreteComponents.Sampler() {^sampler_theta}
  sampler_x = DiscreteComponents.Sampler() {^sampler_x}
  sampler_ref = DiscreteComponents.Sampler() {^sampler_ref}
  zoh = DiscreteComponents.ZeroOrderHold() {^zoh}
  clock = DiscreteComponents.PeriodicClock(dt = Ts) {^clock}
  "Controller sample interval"
  structural parameter Ts::Real = 0.005
relations
  connect(sampler_ref.y, pos_controller.u_s) {^id14}
  connect(pos_controller.y, gain1.u) {^id15}
  connect(gain1.y, angle_controller.u_s) {^id16}
  connect(angle_controller.y, gain.u) {^id17}
  connect(gain.y, zoh.u) {^id18}
  connect(zoh.y, torque) {^id19}
  connect(sampler_theta.u, angle_measurement) {^id20}
  connect(pos_measurement, sampler_x.u) {^id21}
  connect(sampler_x.y, pos_controller.u_m) {^id22}
  connect(sampler_theta.y, angle_controller.u_m, clock.y) {^id23}
  connect(pos_reference, sampler_ref.u) {^id24}
metadata {
  "Dyad": {"icons": {"default": "dyad://DyadBotComponents/DiscreteCascadeController.svg"}},
  "_links": {
    "angle_measurement": {
      "Dyad": {
        "placement": {"diagram": {"x1": 680, "y1": 1000, "x2": 780, "y2": 1100, "rot": 270}}
      }
    },
    "pos_measurement": {
      "Dyad": {
        "placement": {"diagram": {"x1": 240, "y1": 1000, "x2": 340, "y2": 1100, "rot": 270}}
      }
    },
    "pos_reference": {
      "Dyad": {"placement": {"diagram": {"x1": -100, "y1": 450, "x2": 0, "y2": 550}}}
