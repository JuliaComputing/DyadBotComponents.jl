"""
Balancing robot with a cascade control system: an inner loop stabilizes the
body tilt angle and an outer loop controls the position of the robot along
the ground. The position reference is a square wave filtered through two
first-order filters to obtain a smooth reference trajectory.

The outer position controller outputs the tilt-angle reference for the inner
angle controller: to move forward, the robot first has to lean forward.

The six controller gains are exposed as top-level parameters so that they can
be tuned, either one loop at a time with the scripts `scripts/tune_angle_pid.jl`
and `scripts/tune_cascade_pid.jl`, or all simultaneously with
`scripts/tune_cascade_structured.jl`.
"""
component CascadeControlledDyadBot
  world = MultibodyComponents.PlanarMechanics.World(g = 9.82) {^world}
  plant = PlanarDyadBot(phi0 = phi0) {^plant}
  square = BlockComponents.Sources.Square(amplitude = 0.05, frequency = 1 / 10) {^square}
  firstorder = BlockComponents.Continuous.FirstOrder(T = 0.1) {^firstorder}
  firstorder1 = BlockComponents.Continuous.FirstOrder(T = 0.1) {^firstorder1}
  angle_controller = BlockComponents.Continuous.LimPID(final k = k_angle, final Ti = Ti_angle, final Td = Td_angle, Nd = 119.368, y_max = 0.1) {^angle_controller}
  pos_controller = BlockComponents.Continuous.LimPID(final k = k_pos, final Ti = Ti_pos, final Td = Td_pos, Nd = 4.76616, wd = 1, wp = 1, y_max = deg2rad(25.0)) {^pos_controller}
  gain = BlockComponents.Math.Gain(k = -1) {^gain}
  gain1 = BlockComponents.Math.Gain(k = -1) {^gain1}
  constant1 = BlockComponents.Sources.Constant(k = 0) {^constant1}
  constant2 = BlockComponents.Sources.Constant(k = 0) {^constant2}
  "Proportional gain of the inner angle controller"
  parameter k_angle::Real = 0.487401
  "Integrator time constant of the inner angle controller"
  parameter Ti_angle::Time = 0.0587352
  "Derivative time constant of the inner angle controller"
  parameter Td_angle::Time = 0.0420526
  "Proportional gain of the outer position controller"
  parameter k_pos::Real = 0.0666576
  "Integrator time constant of the outer position controller"
  parameter Ti_pos::Time = 5.25024
  "Derivative time constant of the outer position controller"
  parameter Td_pos::Time = 4.81393
  "Initial tilt angle of the body"
  parameter phi0::Angle = 0.1
relations
  initial firstorder.x = 0.0
  initial firstorder1.x = 0.0
  y: analysis_point(plant.theta, angle_controller.u_m)
  y2: analysis_point(plant.x, pos_controller.u_m)
  u: analysis_point(angle_controller.y, gain.u)
  u2: analysis_point(pos_controller.y, gain1.u)
  connect(square.y, firstorder.u) {^id12}
  connect(firstorder.y, firstorder1.u) {^id13}
  connect(plant.x, pos_controller.u_m) {^id14}
  connect(pos_controller.y, gain1.u) {^id15}
  connect(gain1.y, angle_controller.u_s) {^id16}
  connect(plant.theta, angle_controller.u_m) {^id17}
  connect(angle_controller.y, gain.u) {^id18}
  connect(gain.y, plant.torque) {^id19}
  connect(constant1.y, pos_controller.u_ff) {^id20}
  connect(constant2.y, angle_controller.u_ff) {^id21}
  connect(firstorder1.y, pos_controller.u_s) {^id22}
metadata {
  "Dyad": {
    "tests": {"case1": {"stop": 20}},
    "icons": {"default": "dyad://DyadBotComponents/PlanarDyadBot.svg"}
  },
  "_links": {
    "world": {
      "Dyad": {
        "placement": {
