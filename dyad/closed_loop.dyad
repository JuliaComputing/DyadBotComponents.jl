"""
Discrete-time version of `CascadeControlledDyadBot`. Both the inner
tilt-angle loop and the outer position loop are realized with sampled-data
`DiscretePIDStandard` controllers running on a common clock defined by the
top-level structural parameter `Ts`.

The continuous plant measurements (tilt angle and position) are sampled by
`Sampler` blocks, the two discrete controllers run in cascade (the outer
position controller produces the tilt-angle reference for the inner
controller), and a `ZeroOrderHold` reconstructs the continuous motor torque.
The square-wave position reference is smoothed by two continuous first-order
filters before being sampled.

The six controller gains are shared with the continuous
`CascadeControlledDyadBot` and can be tuned with the scripts
`scripts/tune_angle_pid.jl`, `scripts/tune_cascade_pid.jl`, or
`scripts/tune_cascade_structured.jl`.
"""
component DiscreteCascadeControlledDyadBot
  world = MultibodyComponents.PlanarMechanics.World(g = 9.82) {^world}
  plant = PlanarDyadBot(phi0 = phi0) {^plant}
  square = BlockComponents.Sources.Square(amplitude = 0.05, frequency = 1 / 10) {^square}
  firstorder = BlockComponents.Continuous.FirstOrder(T = 0.1) {^firstorder}
  firstorder1 = BlockComponents.Continuous.FirstOrder(T = 0.1) {^firstorder1}
  angle_controller = DiscreteComponents.DiscretePIDStandard(final K = k_angle, final Ti = Ti_angle, final Td = Td_angle, Nd = 119.368, y_max = 0.1) {^angle_controller}
  pos_controller = DiscreteComponents.DiscretePIDStandard(final K = k_pos, final Ti = Ti_pos, final Td = Td_pos, Nd = 4.76616, wd = 1, wp = 1, y_max = deg2rad(25.0)) {^pos_controller}
  gain = BlockComponents.Math.Gain(k = -1) {^gain}
  gain1 = BlockComponents.Math.Gain(k = -1) {^gain1}
  sampler_theta = DiscreteComponents.Sampler() {^sampler_theta}
  sampler_x = DiscreteComponents.Sampler() {^sampler_x}
  sampler_ref = DiscreteComponents.Sampler() {^sampler_ref}
  zoh = DiscreteComponents.ZeroOrderHold() {^zoh}
  clock = DiscreteComponents.PeriodicClock(dt = Ts) {^clock}
  "Proportional gain of the inner angle controller"
  parameter k_angle::Real = 0.487401
  "Integrator time constant of the inner angle controller"
  parameter Ti_angle::Time = 0.0587352
  "Derivative time constant of the inner angle controller"
  parameter Td_angle::Time = 0.0420526
  "Proportional gain of the outer position controller"
  parameter k_pos::Real = 0.0666576
  "Integrator time constant of the outer position controller"
  parameter Ti_pos::Time = 5.25024
  "Derivative time constant of the outer position controller"
  parameter Td_pos::Time = 4.81393
  "Initial tilt angle of the body"
  parameter phi0::Angle = 0.1
  "Controller sample interval"
  structural parameter Ts::Real = 0.005
relations
  initial firstorder.x = 0.0
  initial firstorder1.x = 0.0
  connect(square.y, firstorder.u) {^id12}
  connect(firstorder.y, firstorder1.u) {^id13}
  connect(firstorder1.y, sampler_ref.u) {^id14}
  connect(sampler_ref.y, pos_controller.reference) {^id15}
  connect(plant.x, sampler_x.u) {^id16}
  connect(sampler_x.y, pos_controller.measurement) {^id17}
  connect(pos_controller.ctr_output, gain1.u) {^id18}
  connect(gain1.y, angle_controller.reference) {^id19}
  connect(plant.theta, sampler_theta.u) {^id20}
  connect(sampler_theta.y, angle_controller.measurement, clock.y) {^id21}
  connect(angle_controller.ctr_output, gain.u) {^id22}
  connect(gain.y, zoh.u) {^id23}
  connect(zoh.y, plant.torque) {^id24}
metadata {
