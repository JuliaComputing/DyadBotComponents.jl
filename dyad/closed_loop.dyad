"""
Discrete-time version of `AngleControlledDyadBot`. The balancing robot is
stabilized by a single sampled-data PID controller regulating the body tilt
angle to zero. The tilt angle is sampled by a `Sampler`, the discrete
`DiscretePIDStandard` computes the control action once per clock tick, and a
`ZeroOrderHold` reconstructs the continuous motor torque. The sample interval
is set by the top-level structural parameter `Ts` via a `PeriodicClock`.

The controller gains are shared with the continuous `AngleControlledDyadBot`
and can be tuned with the script `scripts/tune_angle_pid.jl`.
"""
component DiscreteAngleControlledDyadBot
  world = MultibodyComponents.PlanarMechanics.World(g = 9.82) {^world}
  plant = PlanarDyadBot(phi0 = phi0) {^plant}
  angle_controller = DiscreteComponents.DiscretePIDStandard(final K = k_angle, final Ti = Ti_angle, final Td = Td_angle, Nd = 119.368, y_max = 0.1) {^angle_controller}
  ref = BlockComponents.Sources.Constant(k = 0) {^ref}
  gain = BlockComponents.Math.Gain(k = -1) {^gain}
  sampler = DiscreteComponents.Sampler() {^sampler}
  zoh = DiscreteComponents.ZeroOrderHold() {^zoh}
  clock = DiscreteComponents.PeriodicClock(dt = Ts) {^clock}
  "Proportional gain of the angle controller"
  parameter k_angle::Real = 0.487401
  "Integrator time constant of the angle controller"
  parameter Ti_angle::Time = 0.0587352
  "Derivative time constant of the angle controller"
  parameter Td_angle::Time = 0.0420526
  "Initial tilt angle of the body"
  parameter phi0::Angle = 0.1
  "Controller sample interval"
  structural parameter Ts::Real = 0.005
relations
  connect(plant.theta, sampler.u) {^id7}
  connect(sampler.y, angle_controller.measurement, clock.y) {^id8}
  connect(ref.y, angle_controller.reference) {^id9}
  connect(angle_controller.ctr_output, zoh.u) {^id10}
  connect(zoh.y, gain.u) {^id11}
  connect(gain.y, plant.torque) {^id12}
metadata {
  "Dyad": {
    "tests": {"case1": {"stop": 5}},
    "icons": {"default": "dyad://DyadBotComponents/PlanarDyadBot.svg"}
  },
  "_links": {
