"""
Continuous-time angle control system for the balancing robot: a single PID
controller (`BlockComponents.Continuous.LimPID`) regulating the body tilt
angle to zero, followed by the sign-flipping actuator gain. The control system
has a purely continuous interface (tilt-angle `measurement` in, motor `torque`
out) so that it can be swapped for its discrete-time counterpart
`DiscreteAngleController` without any other change to the closed-loop model.

The reference is held internally at zero. The analysis points `y` (angle
measurement) and `u` (controller output) are exposed for loop-shaping and
PID autotuning.
"""
component AngleController
  extends AngleControllerParams
  "Body tilt-angle measurement"
  measurement = Dyad.RealInput() {^measurement}
  "Motor torque command"
  torque = Dyad.RealOutput() {^torque}
  angle_controller = BlockComponents.Continuous.LimPID(final k = k_angle, final Ti = Ti_angle, final Td = Td_angle, Nd = 119.368, y_max = 0.1) {^angle_controller}
  ref = BlockComponents.Sources.Constant(k = 0) {^ref}
  gain = BlockComponents.Math.Gain(k = -1) {^gain}
  constant_ff = BlockComponents.Sources.Constant(k = 0) {^constant_ff}
relations
  y: analysis_point(measurement, angle_controller.u_m)
  u: analysis_point(angle_controller.y, gain.u)
  connect(measurement, angle_controller.u_m) {^id7}
  connect(angle_controller.y, gain.u) {^id8}
  connect(gain.y, torque) {^id9}
  connect(constant_ff.y, angle_controller.u_ff) {^id10}
  connect(ref.y, angle_controller.u_s) {^id11}
metadata {
  "Dyad": {"icons": {"default": "dyad://DyadBotComponents/AngleController.svg"}},
  "_links": {
    "measurement": {
      "Dyad": {"placement": {"diagram": {"x1": -100, "y1": 450, "x2": 0, "y2": 550}}}
    },
    "torque": {
      "Dyad": {"placement": {"diagram": {"x1": 1000, "y1": 450, "x2": 1100, "y2": 550}}}
    },
    "angle_controller": {
      "Dyad": {"placement": {"diagram": {"x1": 170, "y1": 450, "x2": 270, "y2": 550}}}
    },
    "ref": {
      "Dyad": {"placement": {"diagram": {"x1": 10, "y1": 350, "x2": 110, "y2": 450}}}
    },
    "gain": {
      "Dyad": {"placement": {"diagram": {"x1": 400, "y1": 460, "x2": 480, "y2": 540}}}
    },
    "constant_ff": {
      "Dyad": {
        "placement": {"diagram": {"x1": 190, "y1": 330, "x2": 250, "y2": 390, "rot": 90}}
      }
    },
    "id7": {
      "Dyad": {"edges": [{"S": 1, "M": [{"x": 30, "y": 500}, {"x": 30, "y": 523}], "E": 2}]}
    },
    "id8": {"Dyad": {"edges": [{"S": 1, "M": [], "E": 2}]}},
    "id9": {"Dyad": {"edges": [{"S": 1, "M": [], "E": 2}]}},
    "id10": {"Dyad": {"edges": [{"S": 1, "M": [], "E": 2}]}},
    "id11": {
      "Dyad": {"edges": [{"S": 1, "M": [{"x": 140, "y": 400}, {"x": 140, "y": 477}], "E": 2}]}
    }
  }
}
end

"""
Discrete-time angle control system for the balancing robot. Drop-in replacement
for `AngleController`: same continuous interface (tilt-angle `measurement` in,
motor `torque` out), but the control law is realized with a sampled-data
`DiscretePIDStandard`. The measurement is sampled by a `Sampler`, the discrete
controller runs once per clock tick on a `PeriodicClock` with period `Ts`, and a
`ZeroOrderHold` reconstructs the continuous torque.
"""
component DiscreteAngleController
  extends AngleControllerParams
  "Body tilt-angle measurement"
  measurement = Dyad.RealInput() {^measurement}
  "Motor torque command"
  torque = Dyad.RealOutput() {^torque}
  angle_controller = DiscreteComponents.DiscretePIDStandard(final K = k_angle, final Ti = Ti_angle, final Td = Td_angle, Nd = 119.368, y_max = 0.1) {^angle_controller}
  ref = BlockComponents.Sources.Constant(k = 0) {^ref}
  gain = BlockComponents.Math.Gain(k = -1) {^gain}
  sampler = DiscreteComponents.Sampler() {^sampler}
  zoh = DiscreteComponents.ZeroOrderHold() {^zoh}
  clock = DiscreteComponents.PeriodicClock(dt = Ts) {^clock}
  "Controller sample interval"
  structural parameter Ts::Real = 0.005
relations
  connect(measurement, sampler.u) {^id9}
  connect(sampler.y, angle_controller.u_m, clock.y) {^id10}
  connect(ref.y, angle_controller.u_s) {^id11}
  connect(gain.y, torque) {^id12}
  connect(angle_controller.y, zoh.u) {^id13}
  connect(zoh.y, gain.u) {^id14}
metadata {
  "Dyad": {"icons": {"default": "dyad://DyadBotComponents/DiscreteAngleController.svg"}},
  "_links": {
    "measurement": {
      "Dyad": {"placement": {"diagram": {"x1": -100, "y1": 450, "x2": 0, "y2": 550}}}
    },
    "torque": {
      "Dyad": {"placement": {"diagram": {"x1": 1000, "y1": 450, "x2": 1100, "y2": 550}}}
    },
    "angle_controller": {
      "Dyad": {"placement": {"diagram": {"x1": 370, "y1": 450, "x2": 470, "y2": 550}}}
    },
    "ref": {
      "Dyad": {"placement": {"diagram": {"x1": 150, "y1": 280, "x2": 250, "y2": 380}}}
    },
    "gain": {
      "Dyad": {"placement": {"diagram": {"x1": 720, "y1": 460, "x2": 800, "y2": 540}}}
    },
    "sampler": {
      "Dyad": {"placement": {"diagram": {"x1": 150, "y1": 470, "x2": 250, "y2": 570}}}
    },
    "zoh": {
      "Dyad": {"placement": {"diagram": {"x1": 560, "y1": 450, "x2": 660, "y2": 550}}}
    },
    "clock": {
      "Dyad": {"placement": {"diagram": {"x1": 360, "y1": 630, "x2": 460, "y2": 730}}}
    },
