"""
Continuous-time cascade control system for the balancing robot. An inner PID
loop stabilizes the body tilt angle and an outer PID loop controls the position
of the robot along the ground; the outer controller outputs the tilt-angle
reference for the inner controller (to move forward, the robot first leans
forward).

The control system has a purely continuous interface (`angle_measurement`,
`pos_measurement` and the filtered `pos_reference` in, motor `torque` out) so it
can be swapped for `DiscreteCascadeController` without any other change to the
closed-loop model. Analysis points `y`/`u` (angle loop) and `y2`/`u2` (position
loop) are exposed for tuning.
"""
component CascadeController
  extends CascadeControllerParams
  "Body tilt-angle measurement"
  angle_measurement = Dyad.RealInput() {^angle_measurement}
  "Wheel-axis position measurement"
  pos_measurement = Dyad.RealInput() {^pos_measurement}
  "Filtered position reference"
  pos_reference = Dyad.RealInput() {^pos_reference}
  "Motor torque command"
  torque = Dyad.RealOutput() {^torque}
  angle_controller = BlockComponents.Continuous.LimPID(final k = k_angle, final Ti = Ti_angle, final Td = Td_angle, Nd = 119.368, y_max = 0.1) {^angle_controller}
  pos_controller = BlockComponents.Continuous.LimPID(final k = k_pos, final Ti = Ti_pos, final Td = Td_pos, Nd = 4.76616, wd = 1, wp = 1, y_max = deg2rad(25.0)) {^pos_controller}
  gain = BlockComponents.Math.Gain(k = -1) {^gain}
  gain1 = BlockComponents.Math.Gain(k = -1) {^gain1}
  constant1 = BlockComponents.Sources.Constant(k = 0) {^constant1}
  constant2 = BlockComponents.Sources.Constant(k = 0) {^constant2}
relations
  y: analysis_point(angle_measurement, angle_controller.u_m)
  y2: analysis_point(pos_measurement, pos_controller.u_m)
  u: analysis_point(angle_controller.y, gain.u)
  u2: analysis_point(pos_controller.y, gain1.u)
  connect(pos_measurement, pos_controller.u_m) {^id11}
  connect(pos_controller.y, gain1.u) {^id12}
  connect(gain1.y, angle_controller.u_s) {^id13}
  connect(angle_measurement, angle_controller.u_m) {^id14}
  connect(angle_controller.y, gain.u) {^id15}
  connect(gain.y, torque) {^id16}
  connect(constant1.y, pos_controller.u_ff) {^id17}
  connect(constant2.y, angle_controller.u_ff) {^id18}
  connect(pos_reference, pos_controller.u_s) {^id19}
metadata {
  "Dyad": {"icons": {"default": "dyad://DyadBotComponents/CascadeController.svg"}},
  "_links": {
    "angle_measurement": {
      "Dyad": {
        "placement": {"diagram": {"x1": 670, "y1": 1000, "x2": 770, "y2": 1100, "rot": 270}}
      }
    },
    "pos_measurement": {
      "Dyad": {
        "placement": {"diagram": {"x1": 320, "y1": 1100, "x2": 220, "y2": 1000, "rot": 90}}
      }
    },
    "pos_reference": {
