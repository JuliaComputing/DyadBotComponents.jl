    },
    "id10": {
      "Dyad": {
        "edges": [
          {"S": 1, "M": [{"x": 300, "y": 520}, {"x": 300, "y": 524}], "E": -1},
          {"S": -1, "M": [], "E": 2},
          {"S": 3, "M": [{"x": 310, "y": 680}], "E": -1}
        ],
        "junctions": [{"x": 310, "y": 524}]
      }
    },
    "id11": {
      "Dyad": {"edges": [{"S": 1, "M": [{"x": 325, "y": 330}, {"x": 325, "y": 472}], "E": 2}]}
    },
    "id12": {"Dyad": {"edges": [{"S": 1, "M": [], "E": 2}]}},
